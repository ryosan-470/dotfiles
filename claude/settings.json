{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_SIMPLE_SYSTEM_PROMPT": "1"
  },
  "includeCoAuthoredBy": false,
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Glob",
      "Grep",
      "Read",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:pkg.go.dev)",
      "WebSearch",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr view *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh repo list *)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh search *)",
      "Bash(gh workflow list *)",
      "Bash(gh workflow view *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git remote *)",
      "Bash(git show *)",
      "Bash(git stash list *)",
      "Bash(git status *)",
      "Bash(git tag *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/config)",
      "Read(~/.ssh/**)",
      "Bash(brew *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(gh auth *)",
      "Bash(gh gpg-key *)",
      "Bash(gh issue close *)",
      "Bash(gh issue delete *)",
      "Bash(gh pr close *)",
      "Bash(gh pr delete *)",
      "Bash(gh release delete *)",
      "Bash(gh repo archive *)",
      "Bash(gh repo create *)",
      "Bash(gh repo delete *)",
      "Bash(gh repo edit *)",
      "Bash(gh repo fork *)",
      "Bash(gh repo rename *)",
      "Bash(gh secret *)",
      "Bash(gh ssh-key *)",
      "Bash(gh variable *)",
      "Bash(gh workflow disable *)",
      "Bash(gh workflow enable *)",
      "Bash(rm -rf *)",
      "Bash(git checkout -- . *)",
      "Bash(git clean -fd *)",
      "Bash(shutdown *)",
      "Bash(sudo *)"
    ],
    "ask": [
      "Bash(gh api *)",
      "Bash(gh issue comment *)",
      "Bash(gh issue edit *)",
      "Bash(gh pr create *)",
      "Bash(gh pr edit *)",
      "Bash(gh pr comment *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr review *)",
      "Bash(git commit *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push origin --force *)",
      "Bash(git push origin -f *)",
      "Bash(git reset --hard *)",
      "Bash(git restore *)",
      "Bash(git push *)",
      "Bash(rm *)",
      "Bash(mv *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$(uname)\" = 'Darwin' ]; then osascript -e 'display notification \"Claude Code が入力を待っています\" with title \"Claude Code\"'; fi"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$(uname)\" = 'Darwin' ]; then osascript -e 'display notification \"Claude Code が許可を求めています\" with title \"Claude Code\"'; fi",
            "async": true
          },
          {
            "type": "command",
            "command": "if command -v ccgate >/dev/null 2>&1; then ccgate claude; fi"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "hookify@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "agent-toolkit-for-aws": {
      "source": {
        "source": "github",
        "repo": "aws/agent-toolkit-for-aws"
      }
    },
    "ryosan-470-plugins": {
      "source": {
        "source": "github",
        "repo": "ryosan-470/claude-plugins"
      },
      "autoUpdate": true
    }
  },
  "language": "日本語",
  "teammateMode": "tmux",
  "theme": "dark-ansi",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "effortLevel": "high",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.dotconfig/dotfiles/claude/statusline.sh"
  },
  "model": "haiku"
}
