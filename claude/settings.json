{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh repo list:*)",
      "Bash(gh run view:*)"
    ],
    "deny": [
      "Bash(gh issue close:*)",
      "Bash(gh issue delete:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr delete:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh repo delete:*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$(uname)\" = 'Darwin' ]; then osascript -e 'display notification \"Claude Code が入力を待っています\" with title \"Claude Code\"'; fi"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$(uname)\" = 'Darwin' ]; then osascript -e 'display notification \"Claude Code が許可を求めています\" with title \"Claude Code\"'; fi",
            "async": true
          }
        ]
      }
    ]
  },
  "language": "日本語",
  "effortLevel": "medium"
}
